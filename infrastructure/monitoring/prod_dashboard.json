{
  "displayName": "Venue Smart System - Production Health",
  "gridLayout": {
    "columns": "2",
    "widgets": [
      {
        "title": "SERVICE HEALTH OVERVIEW",
        "xyChart": {
          "dataSets": [
            {
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"run.googleapis.com/request_latencies\" AND resource.type=\"cloud_run_revision\" AND metric.labels.response_code_class=\"5xx\"",
                  "aggregation": {
                    "perSeriesAligner": "ALIGN_RATE"
                  }
                }
              }
            }
          ],
          "thresholds": [
            { "label": "Warning", "value": 0.001, "color": "YELLOW" },
            { "label": "Critical", "value": 0.01, "color": "RED" }
          ]
        }
      },
      {
        "title": "LATENCY PERCENTILES",
        "xyChart": {
          "dataSets": [
            {
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"run.googleapis.com/request_latencies\"",
                  "aggregation": {
                    "crossSeriesReducer": "REDUCE_PERCENTILE_95",
                    "perSeriesAligner": "ALIGN_DELTA"
                  }
                }
              }
            }
          ]
        }
      },
      {
        "title": "FIREBASE RTDB CONNECTION COUNT",
        "xyChart": {
          "dataSets": [
            {
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"firebasedatabase.googleapis.com/io/active_connections\""
                }
              }
            }
          ],
          "thresholds": [ { "value": 45000, "color": "RED", "label": "90% Quota Match" } ]
        }
      },
      {
        "title": "PUB/SUB MESSAGE THROUGHPUT",
        "xyChart": {
          "dataSets": [
            {
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"pubsub.googleapis.com/topic/send_request_count\""
                }
              }
            }
          ]
        }
      },
      {
        "title": "CLOUD RUN INSTANCE COUNT",
        "xyChart": {
          "dataSets": [
            {
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"run.googleapis.com/container/instance_count\""
                }
              }
            }
          ],
          "thresholds": [{ "value": 20, "color": "RED", "label": "Ceiling Limit" }]
        }
      },
      {
        "title": "BIGQUERY WRITE THROUGHPUT",
        "xyChart": {
          "dataSets": [
            {
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"bigquery.googleapis.com/storage/uploaded_bytes\""
                }
              }
            }
          ]
        }
      }
    ]
  }
}
